# LLM API Keys
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=key-...
# GOOGLE_API_KEY=key-...      # also accepted for Gemini; takes precedence over GEMINI_API_KEY

# Encrypts secrets at rest (users' Modal tokens). Set this in production from a
# secrets manager; any string works (a key is derived from it). If unset, a key
# file is generated under the workspace — fine for local/dev, weaker for prod.
# DEEP_HARNESS_SECRET_KEY=change-me-to-a-long-random-string

# Optional overrides (defaults shown)
DEEP_AGENT_MODEL=openai:gpt-5.5
DEEP_AGENT_WORKSPACE=workspace
DATABASE_URL=sqlite:///workspace/data.db
DATA_DICTIONARY_PATH=workspace/data_dictionary.json
KNOWLEDGE_GRAPH_PATH=workspace/knowledge_graph.ttl

# Compute backend for the CLI (the web app configures this per user in the UI)
DEEP_AGENT_COMPUTE=local        # local | modal
DEEP_AGENT_GPU=A10G             # T4 | L4 | A10G | A100 | H100 (modal only)
# MODAL_TOKEN_ID=ak-...
# MODAL_TOKEN_SECRET=as-...

# Deep research
# TAVILY_API_KEY=tvly-...          # optional: general web search for the researcher
# RESEARCH_SERVER_URL=http://localhost:8010   # optional: async research server
